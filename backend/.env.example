# Copy this file to .env and fill in real values before starting the server
# Example:
# SUPABASE_URL=https://xyzcompany.supabase.co
# SUPABASE_KEY=your-service-role-or-api-key

SUPABASE_URL=
SUPABASE_KEY=
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/generic_db

# Security & JWT
JWT_SECRET=your_super_secret_jwt_signature_key_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
